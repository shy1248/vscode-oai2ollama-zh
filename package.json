{
    "name": "oai2ollama",
    "displayName": "%extension.displayName%",
    "description": "%extension.description%",
    "version": "1.0.0",
    "publisher": "shy",
    "icon": "logo.png",
    "author": {
        "name": "shy",
        "email": "hengchen2005@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/shy1248/vscode-oai2ollama-zh.git",
        "directory": "vscode-oai2ollama-zh"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "configuration": {
            "title": "%configuration.title%",
            "properties": {
                "oai2ollama.apiKey": {
                    "type": "string",
                    "default": "",
                    "description": "%configuration.apiKey.description%",
                    "order": 1
                },
                "oai2ollama.baseUrl": {
                    "type": "string",
                    "default": "",
                    "description": "%configuration.baseUrl.description%",
                    "order": 2
                },
                "oai2ollama.host": {
                    "type": "string",
                    "default": "localhost",
                    "description": "%configuration.host.description%",
                    "order": 3
                },
                "oai2ollama.port": {
                    "type": "number",
                    "default": 11434,
                    "description": "%configuration.port.description%",
                    "order": 4
                },
                "oai2ollama.capabilities": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "tools",
                            "insert",
                            "vision",
                            "embedding",
                            "thinking",
                            "completion"
                        ]
                    },
                    "default": [],
                    "description": "%configuration.capabilities.description%",
                    "order": 5
                },
                "oai2ollama.models": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "%configuration.models.description%",
                    "order": 6
                },
                "oai2ollama.autoStart": {
                    "type": "boolean",
                    "default": false,
                    "description": "%configuration.autostart.descripton%",
                    "order": 7
                }
            }
        },
        "commands": [
            {
                "command": "oai2ollama.start",
                "title": "%command.start%"
            },
            {
                "command": "oai2ollama.stop",
                "title": "%command.stop%"
            },
            {
                "command": "oai2ollama.restart",
                "title": "%command.restart%"
            },
            {
                "command": "oai2ollama.showStatus",
                "title": "%command.showStatus%"
            },
            {
                "command": "oai2ollama.openSettings",
                "title": "%command.openSettings%"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile",
        "lint": "eslint src --ext ts",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/node": "^20.x",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "^6.x",
        "@typescript-eslint/parser": "^6.x",
        "eslint": "^8.x",
        "typescript": "^5.x",
        "@vscode/vsce": "^2.x"
    }
}